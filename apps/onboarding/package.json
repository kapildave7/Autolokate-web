{
  "name": "@autolokate/onboarding",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",

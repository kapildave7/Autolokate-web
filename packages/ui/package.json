{
  "name": "@autolokate/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assets/sos-emergency-alarm.wav": "./dist/assets/sos-emergency-alarm.wav"
  },
  "scripts": {
    "build": "tsc --build && mkdir -p dist/assets && cp src/assets/*.wav dist/assets/ 2>/dev/null || true",
    "generate:sos-alarm": "node scripts/generate-sos-alarm.mjs",
    "dev": "tsc --build --watch",
    "lint": "eslint .",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@autolokate/design-system": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "files": [
    "dist",
    "src/components/**/*.css",
    "src/assets/*.wav"
  ]
}
